# =============================================================
# LLM Configuration
# =============================================================
# The LLM client uses the OpenAI-compatible API format.
# You can point it at ANY of these providers directly:
#
# OpenAI:          LLM_BASE_URL=https://api.openai.com/v1
#                  LLM_MODEL=gpt-4o
#
# Azure OpenAI:    LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT
#                  LLM_MODEL=gpt-4o  (your deployment name)
#                  (set LLM_API_KEY to your Azure API key)
#
# Anthropic:       LLM_BASE_URL=https://api.anthropic.com/v1
#                  LLM_MODEL=claude-sonnet-4-20250514
#                  (Note: requires LiteLLM proxy for OpenAI-compatible format)
#
# LiteLLM Proxy:   LLM_BASE_URL=http://localhost:4000  (or your deployed proxy URL)
#                  LLM_MODEL=default
#                  (Recommended — lets you switch models without code changes)
#
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key
LLM_MODEL=gpt-4o

# =============================================================
# Supabase
# =============================================================
# Use the publishable key (recommended) or legacy anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key  # legacy, still works
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# GitHub (optional — increases API rate limit from 60 to 5000/hr)
# =============================================================
GITHUB_TOKEN=

# =============================================================
# Social Publishing (future)
# =============================================================
BUFFER_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

# =============================================================
# Telegram Review Bot (future)
# =============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
